{
  "compilerOptions": {
    "target": "ES2023",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "moduleDetection": "force",
    "lib": ["ES2023"],
    "outDir": "./dist",
    "rootDir": "./src",

    // Strict type checking (maximum safety — TS 6 default is strict:true)
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "noFallthroughCasesInSwitch": true,

    // Module & interop
    // esModuleInterop/allowSyntheticDefaultImports removed — always-on in TS 6
    "verbatimModuleSyntax": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "erasableSyntaxOnly": true,

    // Emit options
    "declaration": true,
    "declarationMap": false,
    "sourceMap": false,
    "noEmit": true,

    // Types — TS 6 changed default to [] (no longer auto-discovers @types/*)
    "types": ["node", "qs"],

    // Other
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "useDefineForClassFields": true
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "**/*.test.ts"]
}
