{
  "name": "@classytic/arc",
  "version": "1.0.0",
  "description": "Resource-oriented backend framework for Fastify + MongoDB",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./permissions": {
      "types": "./dist/permissions/index.d.ts",
      "default": "./dist/permissions/index.js"
    },
    "./types": {
      "types": "./dist/types/index.d.ts",
      "default": "./dist/types/index.js"
    },
    "./adapters": {
      "types": "./dist/adapters/index.d.ts",
      "default": "./dist/adapters/index.js"
    },
    "./presets": {
      "types": "./dist/presets/index.d.ts",
      "default": "./dist/presets/index.js"
    },
    "./presets/tenant": {
      "types": "./dist/presets/multiTenant.d.ts",
      "default": "./dist/presets/multiTenant.js"
    },
    "./auth": {
      "types": "./dist/auth/index.d.ts",
      "default": "./dist/auth/index.js"
    },
    "./org": {
      "types": "./dist/org/index.d.ts",
      "default": "./dist/org/index.js"
    },
    "./hooks": {
      "types": "./dist/hooks/index.d.ts",
      "default": "./dist/hooks/index.js"
    },
    "./registry": {
      "types": "./dist/registry/index.d.ts",
      "default": "./dist/registry/index.js"
    },
    "./utils": {
      "types": "./dist/utils/index.d.ts",
      "default": "./dist/utils/index.js"
    },
    "./cli": {
      "types": "./dist/cli/index.d.ts",
      "default": "./dist/cli/index.js"
    },
    "./plugins": {
      "types": "./dist/plugins/index.d.ts",
      "default": "./dist/plugins/index.js"
    },
    "./audit": {
      "types": "./dist/audit/index.d.ts",
      "default": "./dist/audit/index.js"
    },
    "./docs": {
      "types": "./dist/docs/index.d.ts",
      "default": "./dist/docs/index.js"
    },
    "./idempotency": {
      "types": "./dist/idempotency/index.d.ts",
      "default": "./dist/idempotency/index.js"
    },
    "./events": {
      "types": "./dist/events/index.d.ts",
      "default": "./dist/events/index.js"
    },
    "./testing": {
      "types": "./dist/testing/index.d.ts",
      "default": "./dist/testing/index.js"
    },
    "./policies": {
      "types": "./dist/policies/index.d.ts",
      "default": "./dist/policies/index.js"
    },
    "./factory": {
      "types": "./dist/factory/index.d.ts",
      "default": "./dist/factory/index.js"
    },
    "./migrations": {
      "types": "./dist/migrations/index.d.ts",
      "default": "./dist/migrations/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "arc": "./bin/arc.js"
  },
  "sideEffects": false,
  "files": [
    "dist",
    "bin"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "vitest run tests/e2e",
    "test:unit": "vitest run tests/core tests/hooks tests/utils tests/plugins",
    "prepublishOnly": "npm run typecheck && npm test && npm run build"
  },
  "engines": {
    "node": ">=20"
  },
  "peerDependencies": {
    "@classytic/mongokit": "^3.0.0",
    "fastify": "^5.0.0",
    "mongoose": "^8.0.0 || ^9.0.0",
    "@fastify/compress": "^8.0.0",
    "@fastify/cors": "^10.0.0",
    "@fastify/helmet": "^13.0.0",
    "@fastify/rate-limit": "^10.0.0",
    "@fastify/sensible": "^6.0.0",
    "@fastify/under-pressure": "^9.0.0",
    "@fastify/multipart": "^9.0.0",
    "fastify-raw-body": "^5.0.0",
    "pino-pretty": "^13.0.0"
  },
  "peerDependenciesMeta": {
    "@classytic/mongokit": {
      "optional": true
    },
    "@fastify/compress": {
      "optional": true
    },
    "@fastify/cors": {
      "optional": true
    },
    "@fastify/helmet": {
      "optional": true
    },
    "@fastify/rate-limit": {
      "optional": true
    },
    "@fastify/sensible": {
      "optional": true
    },
    "@fastify/under-pressure": {
      "optional": true
    },
    "@fastify/multipart": {
      "optional": true
    },
    "fastify-raw-body": {
      "optional": true
    },
    "pino-pretty": {
      "optional": true
    },
    "mongodb-memory-server": {
      "optional": true
    },
    "@fastify/aws-lambda": {
      "optional": true
    },
    "@opentelemetry/api": {
      "optional": true
    },
    "@opentelemetry/sdk-node": {
      "optional": true
    },
    "@opentelemetry/exporter-trace-otlp-http": {
      "optional": true
    },
    "@opentelemetry/instrumentation-http": {
      "optional": true
    },
    "@opentelemetry/instrumentation-mongodb": {
      "optional": true
    },
    "@opentelemetry/auto-instrumentations-node": {
      "optional": true
    }
  },
  "dependencies": {
    "fastify-plugin": "^5.0.1"
  },
  "devDependencies": {
    "@classytic/mongokit": "^3.1.0",
    "@fastify/jwt": "^9.0.0",
    "@types/node": "^22.10.0",
    "mongodb-memory-server": "^11.0.1",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^3.0.0"
  },
  "keywords": [
    "fastify",
    "mongodb",
    "mongoose",
    "crud",
    "rest",
    "api",
    "framework",
    "resource",
    "multi-tenant",
    "typescript"
  ],
  "author": "Classytic",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/classytic/arc.git"
  }
}
